       end if ! ( masterproc )
 
 
+!==> MAM4-JAX amicphys init dump (M3.6 PR-C foundation overlay)
+!    Writes the amicphys-internal mapping/conversion tables to
+!    mam4_amicphys_init.txt. These constants are module-private to
+!    modal_aero_amicphys, so the dump has to live inside the module.
+!    Parsed by scripts/capture_reference.py into
+!    tests/reference/indices/reference.npz.
+      block
+         integer :: unit_aa, ia, jm
+         open(newunit=unit_aa, file='mam4_amicphys_init.txt', &
+              status='replace', action='write')
+         write(unit_aa,'(a)') '# MAM4-JAX amicphys init tables.'
+         write(unit_aa,'(a)') "# Section markers begin with '%'."
+         write(unit_aa,'(/a)') '% loffset'
+         write(unit_aa,'(i0)') loffset
+         write(unit_aa,'(/a)') '% ngas'
+         write(unit_aa,'(i0)') ngas
+         write(unit_aa,'(/a)') '% naer'
+         write(unit_aa,'(i0)') naer
+         write(unit_aa,'(/a)') '% max_gas'
+         write(unit_aa,'(i0)') max_gas
+         write(unit_aa,'(/a)') '% max_aer'
+         write(unit_aa,'(i0)') max_aer
+         write(unit_aa,'(/a)') '% lmap_gas (shape: ngas; gas_pcnst-relative)'
+         write(unit_aa,'(*(i0,1x))') (lmap_gas(ia), ia=1, ngas)
+         write(unit_aa,'(/a)') '% lmap_num (shape: ntot_amode; gas_pcnst-relative)'
+         write(unit_aa,'(*(i0,1x))') (lmap_num(jm), jm=1, ntot_amode)
+         write(unit_aa,'(/a)') '% lmap_numcw (shape: ntot_amode; gas_pcnst-relative)'
+         write(unit_aa,'(*(i0,1x))') (lmap_numcw(jm), jm=1, ntot_amode)
+         write(unit_aa,'(/a)') '% lmap_aer (shape: naer x ntot_amode; row=iaer slot)'
+         do jm = 1, ntot_amode
+            write(unit_aa,'(*(i0,1x))') (lmap_aer(ia, jm), ia=1, naer)
+         end do
+         write(unit_aa,'(/a)') '% lmap_aercw (shape: naer x ntot_amode)'
+         do jm = 1, ntot_amode
+            write(unit_aa,'(*(i0,1x))') (lmap_aercw(ia, jm), ia=1, naer)
+         end do
+         write(unit_aa,'(/a)') '% fcvt_gas (shape: ngas)'
+         write(unit_aa,'(*(1pe23.15,1x))') (fcvt_gas(ia), ia=1, ngas)
+         write(unit_aa,'(/a)') '% fcvt_aer (shape: naer)'
+         write(unit_aa,'(*(1pe23.15,1x))') (fcvt_aer(ia), ia=1, naer)
+         write(unit_aa,'(/a,1x,1pe23.15)') '% fcvt_num', fcvt_num
+         write(unit_aa,'(/a,1x,1pe23.15)') '% fcvt_wtr', fcvt_wtr
+         write(unit_aa,'(/a,1x,1pe23.15)') '% mwdry', mwdry
+         write(unit_aa,'(/a)') '% adv_mass (shape: gas_pcnst; driver mmr->vmr factor = mwdry/adv_mass)'
+         write(unit_aa,'(*(1pe23.15,1x))') (adv_mass(ia), ia=1, gas_pcnst)
+         write(unit_aa,'(/a,1x,1pe23.15)') '% vmdry', vmdry
+         write(unit_aa,'(/a)') '% mw_gas (shape: ngas)'
+         write(unit_aa,'(*(1pe23.15,1x))') (mw_gas(ia), ia=1, ngas)
+         write(unit_aa,'(/a)') '% vol_molar_gas (shape: ngas)'
+         write(unit_aa,'(*(1pe23.15,1x))') (vol_molar_gas(ia), ia=1, ngas)
+         write(unit_aa,'(/a)') '% accom_coef_gas (shape: ngas)'
+         write(unit_aa,'(*(1pe23.15,1x))') (accom_coef_gas(ia), ia=1, ngas)
+         write(unit_aa,'(/a,1x,i0)') '% npoa', npoa
+         write(unit_aa,'(/a,1x,i0)') '% nsoa', nsoa
+         write(unit_aa,'(/a,1x,i0)') '% iaer_pom', iaer_pom
+         write(unit_aa,'(/a,1x,i0)') '% iaer_soa', iaer_soa
+         write(unit_aa,'(/a,1x,i0)') '% npca', npca
+         write(unit_aa,'(/a,1x,i0)') '% nufi', nufi
+         write(unit_aa,'(/a)') '% mode_aging_optaa (shape: ntot_amode)'
+         write(unit_aa,'(*(i0,1x))') (mode_aging_optaa(jm), jm=1, ntot_amode)
+         write(unit_aa,'(/a)') '% lptr2_soa_a_amode (shape: ntot_amode x nsoa; gas_pcnst-relative)'
+         do jm = 1, ntot_amode
+            write(unit_aa,'(*(i0,1x))') (lptr2_soa_a_amode(jm, ia), ia=1, nsoa)
+         end do
+         write(unit_aa,'(/a,1x,1pe23.15)') '% mw_so4a_host', mw_so4a_host
+         write(unit_aa,'(/a,1x,1pe23.15)') '% mw_nh4a_host', mw_nh4a_host
+         write(unit_aa,'(/a,1x,1pe23.15)') '% dens_so4a_host', dens_so4a_host
+         close(unit_aa)
+      end block
+!==> MAM4-JAX end
+
+
       call m_a_amicphys_init_history( loffset )
